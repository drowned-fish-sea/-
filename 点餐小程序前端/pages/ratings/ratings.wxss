/* pages/ratings/ratings.wxss */
.container {
  min-height: 100vh;
  background: #f5f5f5;
}
.header {
  background: linear-gradient(135deg, #ff9c35 0%, #ff6b35 100%);
  padding: 40rpx 30rpx;
  color: #fff;
}
.header-title {
  font-size: 40rpx;
  font-weight: bold;
}
.header-subtitle {
  font-size: 24rpx;
  margin-top: 10rpx;
  opacity: 0.8;
}
.list {
  padding: 20rpx;
}
.item {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}
.item-left {
  margin-right: 24rpx;
}
.item-image {
  width: 120rpx;
  height: 120rpx;
  border-radius: 12rpx;
}
.item-right {
  flex: 1;
}
.item-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 12rpx;
}
.item-info {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
}
.item-stars {
  margin-right: 12rpx;
}
.item-stars .star {
  font-size: 24rpx;
  color: #ddd;
}
.item-stars .star.active {
  color: #ffcc00;
}
.item-rating {
  font-size: 28rpx;
  color: #ff6b35;
  font-weight: bold;
  margin-right: 12rpx;
}
.item-count {
  font-size: 24rpx;
  color: #999;
}
.item-arrow {
  font-size: 48rpx;
  color: #ccc;
  margin-left: 16rpx;
}
.empty {
  padding: 100rpx 40rpx;
  text-align: center;
}
.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}
.empty-text {
  font-size: 28rpx;
  color: #999;
  line-height: 1.6;
}
.loading {
  padding: 60rpx;
  text-align: center;
  color: #999;
}
