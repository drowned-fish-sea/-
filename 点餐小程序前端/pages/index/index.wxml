<!--index.wxml-->
<swiper class="swiper" indicator-dots="true" autoplay="true" interval="5000" duration="1000">
  <block wx:for="{{ swiper }}" wx:key="*this">
    <swiper-item>
      <image src="{{ item }}" mode="aspectFill"/>
    </swiper-item>
  </block>
</swiper>
<!-- 开启点餐之旅 -->
<view class="menu-bar">
  <view class="menu-block" bindtap="start">
    <view class="menu-start">开启点餐之旅→</view>
  </view>
</view>
<!-- 最新消息展示 -->
<view class="ad-box">
  <image src="{{ ad }}" class="ad-image" mode="aspectFill"/>
</view>
<view class="bottom-box">
  <view class="bottom-pic" wx:for="{{ category }}" wx:key="id">
    <image src="{{item.icon}}" class="bottom-image" mode="aspectFill"/>
  </view>
</view>
